{
	"name": "floor",
	"private": true,
	"engines": {
		"node": ">=20.9.0"
	},
	"scripts": {
		"dev": "webpack serve",
		"prebuild": "node scripts/copy-public.mjs",
		"build": "webpack --mode production",
		"prewatch": "node scripts/copy-public.mjs",
		"watch": "webpack --watch",
		"start": "npm run dev",
		"test": "node --import tsx --test test/*.test.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"check": "npm run lint && npm run typecheck && npm run test && npm run build",
		"format": "biome format --write .",
		"format:check": "biome format --check .",
		"update:deps": "npm update --save",
		"update:deps:latest": "npx npm-check-updates -u && npm install"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"ts-loader": "^9.5.4",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"webpack": "^5.105.4",
		"webpack-cli": "^7.0.2",
		"webpack-dev-server": "^5.2.3"
	}
}
